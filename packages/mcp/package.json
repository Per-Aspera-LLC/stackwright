{
    "name": "@stackwright/mcp",
    "version": "0.3.0-alpha.10",
    "description": "MCP server for Stackwright — exposes content types, page management, and validation as agent tools",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Per-Aspera-LLC/stackwright"
    },
    "bin": {
        "stackwright-mcp": "dist/server.js"
    },
    "main": "./dist/server.js",
    "types": "./dist/server.d.ts",
    "exports": {
        ".": {
            "types": "./dist/server.d.ts",
            "require": "./dist/server.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "prepublishOnly": "pnpm build",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.27.0",
        "@stackwright/cli": "workspace:*",
        "@stackwright/types": "workspace:*",
        "playwright": "^1.52.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/node": "^25.4.0",
        "fs-extra": "^11.3.4",
        "tsup": "^8.5.1",
        "typescript": "^5.6.0"
    }
}
