{
  "name": "@stackwright/icons",
  "version": "0.4.1-alpha.0",
  "description": "Lucide-based icon registry for Stackwright",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Per-Aspera-LLC/stackwright"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "lucide-react": "^1.8.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6",
    "@testing-library/react": "^16.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.2",
    "react": "^19",
    "react-dom": "^19",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^4"
  },
  "peerDependencies": {
    "react": "^19"
  }
}
