{
  "name": "@stackwright/core",
  "type": "module",
  "version": "0.3.1-alpha.2",
  "description": "Core framework for building applications from YAML configuration",
  "main": "./dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./DynamicPage": {
      "types": "./dist/components/DynamicPage.d.ts",
      "import": "./dist/components/DynamicPage.mjs",
      "require": "./dist/components/DynamicPage.js"
    },
    "./pages/slug": {
      "types": "./dist/pages/SlugPage.d.ts",
      "import": "./dist/pages/SlugPage.mjs",
      "require": "./dist/pages/SlugPage.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@emotion/cache": "11.14.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.0",
    "@fontsource/montserrat-alternates": "5.1.1",
    "@mui/icons-material": "6.2.0",
    "@mui/material": "6.2.0",
    "@stackwright/types": "workspace:*",
    "@stackwright/themes": "workspace:*",
    "js-yaml": "^4.1.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@swc/core": "^1.7.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20.19.1",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@stackwright/types": "workspace:*",
    "@vitest/ui": "^3.2.4",
    "jsdom": "^26.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
