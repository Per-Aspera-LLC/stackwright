{
    "name": "@stackwright/core",
    "version": "0.6.0-alpha.15",
    "description": "Core framework for building applications from YAML configuration",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Per-Aspera-LLC/stackwright"
    },
    "main": "./dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./DynamicPage": {
            "types": "./dist/components/DynamicPage.d.ts",
            "import": "./dist/components/DynamicPage.mjs",
            "require": "./dist/components/DynamicPage.js"
        },
        "./pages/slug": {
            "types": "./dist/pages/SlugPage.d.ts",
            "import": "./dist/pages/SlugPage.mjs",
            "require": "./dist/pages/SlugPage.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "@stackwright/collections": "workspace:*",
        "@stackwright/themes": "workspace:*",
        "@stackwright/types": "workspace:*",
        "js-yaml": "^4.1.0",
        "prismjs": "^1.30.0",
        "uuid": "^13.0.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@stackwright/types": "workspace:*",
        "@swc/core": "^1.15.18",
        "@testing-library/jest-dom": "^6.6",
        "@testing-library/react": "^16.3",
        "@types/node": "^25.4",
        "@types/prismjs": "^1.26.6",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitest/ui": "^4.0.18",
        "jsdom": "^28.1.0",
        "react": "^19",
        "react-dom": "^19",
        "tsup": "^8.5",
        "typescript": "^5.8",
        "vitest": "^4.0.18"
    },
    "peerDependencies": {
        "react": "^19",
        "react-dom": "^19"
    }
}
