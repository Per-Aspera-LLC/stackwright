{
    "name": "@stackwright/sbom-generator",
    "version": "0.1.0-alpha.0",
    "description": "SBOM generation for Stackwright projects - generates SPDX, CycloneDX, and build manifest formats",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Per-Aspera-LLC/stackwright"
    },
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "js-yaml": "^4.1.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/js-yaml": "^4.0.0",
        "@types/node": "^20.0.0",
        "tsup": "^8.5.0",
        "typescript": "^5.8.0",
        "vitest": "^4.0.18"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}
