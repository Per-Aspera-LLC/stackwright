{
    "name": "@stackwright/nextjs",
    "version": "0.2.8-alpha.13",
    "description": "Next.js implementations for Stackwright components",
    "repository": {
        "type": "git",
        "url": "https://github.com/Per-Aspera-LLC/stackwright"
    },
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup ",
        "dev": "tsup --watch",
        "test": "vitest",
        "test:run": "vitest run",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "@stackwright/core": "workspace:*",
        "@stackwright/types": "workspace:*",
        "js-yaml": "^4.1.0"
    },
    "devDependencies": {
        "@swc/core": "^1.15.18",
        "@testing-library/jest-dom": "^6.6",
        "@testing-library/react": "^16.3",
        "@types/js-yaml": "^4.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "jsdom": "^28.1.0",
        "next": "^16.1.6",
        "react": "^19",
        "react-dom": "^19",
        "tsup": "^8.5.1",
        "typescript": "^5.8.3",
        "vitest": "^4.0.18"
    },
    "peerDependencies": {
        "next": ">=16.1.6",
        "react": "^19",
        "react-dom": "^19"
    }
}
