{
    "name": "@stackwright/nextjs",
    "version": "0.2.1-alpha.5",
    "description": "Next.js implementations for Stackwright components",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup ",
        "dev": "tsup --watch",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "@stackwright/core": "workspace:*",
        "@stackwright/types": "workspace:*",
        "js-yaml": "^4.1.0",
        "next": "^15",
        "react": "^19",
        "react-dom": "^19"
    },
    "devDependencies": {
        "@swc/core": "^1.13.2",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@types/js-yaml": "^4.0",
        "tsup": "^8.5.0",
        "typescript": "^5.8.3",
        "vitest": "^3.2.4"
    },
    "peerDependencies": {
        "next": "^15",
        "react": "^19",
        "react-dom": "^19"
    }
}
