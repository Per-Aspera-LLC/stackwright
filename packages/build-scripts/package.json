{
    "name": "@stackwright/build-scripts",
    "version": "0.7.0",
    "description": "Build-time scripts for Stackwright projects (prebuild image processing, YAML compilation)",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Per-Aspera-LLC/stackwright"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "require": "./dist/index.js"
        }
    },
    "bin": {
        "stackwright-prebuild": "dist/prebuild.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest run",
        "prepublishOnly": "pnpm run build",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@stackwright/sbom-generator": "workspace:*",
        "@stackwright/types": "workspace:*",
        "js-yaml": "^4.1.0"
    },
    "devDependencies": {
        "@types/js-yaml": "^4.0",
        "@types/node": "^25.4.0",
        "tsup": "^8.5.1",
        "typescript": "^5.8.3",
        "vitest": "^4.0.18"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}
