{
    "name": "@stackwright/build-scripts",
    "version": "0.1.2",
    "description": "Build-time scripts for Stackwright projects (prebuild image processing, YAML compilation)",
    "repository": {
        "type": "git",
        "url": "https://github.com/Per-Aspera-LLC/stackwright"
    },
    "main": "dist/index.js",
    "bin": {
        "stackwright-prebuild": "dist/prebuild.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest run",
        "prepublishOnly": "pnpm run build"
    },
    "dependencies": {
        "@stackwright/types": "workspace:*",
        "js-yaml": "^4.1.0"
    },
    "devDependencies": {
        "@types/js-yaml": "^4.0",
        "@types/node": "^25.3.2",
        "tsup": "^8.5.0",
        "typescript": "^5.8.3",
        "vitest": "^4.0.18"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}
