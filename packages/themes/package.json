{
  "name": "@stackwright/themes",
  "version": "0.5.0",
  "description": "YAML-configurable theming with dark mode, CSS custom properties, and cookie-based persistence",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Per-Aspera-LLC/stackwright"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "js-yaml": "^4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9",
    "@testing-library/react": "^16.3",
    "@types/js-yaml": "^4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.1",
    "react": "^19",
    "react-dom": "^19",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^4"
  },
  "peerDependencies": {
    "react": "^19"
  }
}
