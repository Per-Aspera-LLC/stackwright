{
  "name": "@stackwright/cli",
  "version": "0.8.1-alpha.0",
  "description": "CLI for Stackwright framework",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Per-Aspera-LLC/stackwright"
  },
  "files": [
    "dist",
    "templates"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "stackwright": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@stackwright/build-scripts": "workspace:*",
    "@stackwright/sbom-generator": "workspace:*",
    "@stackwright/scaffold-core": "workspace:*",
    "@stackwright/themes": "workspace:*",
    "@stackwright/types": "workspace:*",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fs-extra": "^11.3",
    "js-yaml": "^4.1.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "playwright": "^1.52.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0",
    "@types/js-yaml": "^4.0",
    "@types/node": "^25.4",
    "tsup": "^8.5",
    "typescript": "^5.0",
    "vitest": "^4.0.18"
  }
}
