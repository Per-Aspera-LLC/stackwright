{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stackwright Theme Schema",
  "description": "Schema for Stackwright theme YAML files",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Theme name"
    },
    "colors": {
      "type": "object",
      "properties": {
        "primary": { "$ref": "#/definitions/ColorScale" },
        "neutral": { "$ref": "#/definitions/ColorScale" },
        "text": {
          "type": "object",
          "properties": {
            "primary": { "$ref": "#/definitions/Color" },
            "secondary": { "$ref": "#/definitions/Color" },
            "inverse": { "$ref": "#/definitions/Color" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "spacing": {
      "type": "object",
      "properties": {
        "section": {
          "type": "string",
          "description": "CSS classes for section spacing"
        },
        "container": {
          "type": "string", 
          "description": "CSS classes for container layout"
        }
      },
      "additionalProperties": false
    },
    "typography": {
      "type": "object",
      "properties": {
        "hero": {
          "type": "string",
          "description": "CSS classes for hero text"
        },
        "subtitle": {
          "type": "string",
          "description": "CSS classes for subtitle text"
        }
      },
      "additionalProperties": false
    },
    "components": {
      "type": "object",
      "properties": {
        "button": {
          "type": "object",
          "properties": {
            "primary": { "type": "string" },
            "secondary": { "type": "string" }
          },
          "additionalProperties": false
        },
        "header": {
          "type": "object",
          "properties": {
            "background": { "type": "string" },
            "border": { "type": "string" }
          },
          "additionalProperties": false
        },
        "hero": {
          "type": "object",
          "properties": {
            "background": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["name", "colors"],
  "additionalProperties": false,
  "definitions": {
    "Color": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$",
      "description": "Hex color code"
    },
    "ColorScale": {
      "type": "object",
      "properties": {
        "50": { "$ref": "#/definitions/Color" },
        "100": { "$ref": "#/definitions/Color" },
        "500": { "$ref": "#/definitions/Color" },
        "600": { "$ref": "#/definitions/Color" },
        "700": { "$ref": "#/definitions/Color" },
        "800": { "$ref": "#/definitions/Color" },
        "900": { "$ref": "#/definitions/Color" }
      },
      "additionalProperties": false
    }
  }
}
