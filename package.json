{
    "name": "stackwright-workspace",
    "version": "0.2.0",
    "private": true,
    "scripts": {
        "build": "pnpm -r --filter='!./examples/**' build",
        "build:types": "pnpm --filter @stackwright/types build",
        "build:all": "pnpm -r build",
        "build:examples": "pnpm -r --filter='examples/*' build",
        "dev": "pnpm -r dev",
        "build:core": "pnpm --filter @stackwright/core build",
        "build:cli": "pnpm --filter @stackwright/cli build",
        "build:themes": "pnpm --filter @stackwright/themes build",
        "build:nextjs": "pnpm --filter @stackwright/nextjs build",
        "build:build-scripts": "pnpm --filter @stackwright/build-scripts build",
        "build:collections": "pnpm --filter @stackwright/collections build",
        "build:mcp": "pnpm --filter @stackwright/mcp build",
        "build:launch-stackwright": "pnpm --filter launch-stackwright build",
        "dev:hellostackwright": "pnpm --filter stackwright-example-app dev",
        "build:hellostackwright": "pnpm --filter stackwright-example-app build",
        "changeset": "changeset",
        "version-packages": "changeset version",
        "release": "pnpm build && changeset publish",
        "test": "pnpm -r --filter='!@stackwright/e2e' --filter='!launch-stackwright' test",
        "test:core": "pnpm --filter @stackwright/core test",
        "test:e2e": "pnpm --filter @stackwright/e2e test",
        "test:coverage": "pnpm -r --filter='!@stackwright/e2e' --filter='!launch-stackwright' test:coverage && node scripts/merge-coverage.js",
        "test:coverage:ui": "pnpm test:coverage && open coverage/merged/index.html",
        "stackwright": "node packages/cli/dist/cli.js",
        "stackwright-mcp": "node packages/mcp/dist/server.js",
        "lint": "eslint packages/",
        "lint:fix": "eslint --fix packages/",
        "format": "prettier --write \"packages/*/{src,test}/**/*.{ts,tsx}\"",
        "format:check": "prettier --check \"packages/*/{src,test}/**/*.{ts,tsx}\""
    },
    "devDependencies": {
        "@changesets/cli": "^2.30.0",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "^8.56.1",
        "@vitest/coverage-v8": "^4.1.2",
        "eslint": "^9.39.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "prettier": "^3.8.1",
        "vitest": "^4.1.2"
    },
    "pnpm": {
        "overrides": {
            "@types/node": "^24.1.0",
            "csstype": "^3.2.0",
            "typescript": "^5.8.3",
            "tsup": "^8.5.0",
            "react": "19.2.4",
            "react-dom": "19.2.4",
            "vitest": "^4.1.2",
            "rollup": ">=4.59.0",
            "minimatch": ">=9.0.7",
            "glob": ">=10.5.0",
            "vite": ">=7.1.11",
            "lodash": ">=4.17.23",
            "diff": ">=4.0.4",
            "tmp": ">=0.2.4",
            "undici": ">=7.24.0",
            "flatted": ">=3.4.0",
            "hono": ">=4.12.7",
            "@hono/node-server": ">=1.19.10",
            "express-rate-limit": ">=8.2.2"
        },
        "onlyBuiltDependencies": [
            "@swc/core",
            "esbuild",
            "sharp",
            "unrs-resolver"
        ]
    }
}
