{
  "name": "stackwright-workspace",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "build": "pnpm generate-schemas && pnpm -r --filter='!./examples/**' build",
    "build:all": "pnpm -r build",
    "build:examples": "pnpm -r --filter='examples/*' build",
    "dev": "pnpm -r dev",
    "build:core": "pnpm --filter @stackwright/core build",
    "build:cli": "pnpm --filter @stackwright/cli build",
    "build:themes": "pnpm --filter @stackwright/themes build",
    "build:nextjs": "pnpm --filter @stackwright/nextjs build",
    "dev:example": "pnpm --filter per-aspera-site dev",
    "build:example": "pnpm --filter per-aspera-site build",
    "generate-schemas": "npx ts-node scripts/generate-schemas.ts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "test": "pnpm -r test",
    "test:core": "pnpm --filter @stackwright/core test"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@types/fs-extra": "^11.0.4",
    "fs-extra": "^11.3.0",
    "ts-morph": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}