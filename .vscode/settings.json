{
  "yaml.schemas": {
    "./packages/types/dist/schemas/content-schema.json": [
      "**/pages/*/content.yaml",
      "**pages/*/content.yml"
    ],
    "./packages/types/dist/schemas/theme-schema.json": [
      "**/themes/*.yaml",
      "**/themes/*.yml"
    ],
    "./packages/types/dist/schemas/site-config-schema.json": [
      "**/stackwright.yaml",
      "**/stackwright.yml",
      "**/site-config.yaml",
      "**/site-config.yml"
    ]
  },
  "yaml.validate": true,
  "yaml.completion": true,
  "yaml.hover": true,
  "yaml.format.enable": true,
  "files.associations": {
    "**/pages/*/content.yaml": "yaml"
  }
}